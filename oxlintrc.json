{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc/json-schema/npm/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "out",
    ".next",
    "*.min.js",
    "apps/backend/convex/_generated"
  ],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": "warn"
  }
}
